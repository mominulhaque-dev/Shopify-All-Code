<section id="pro-carousel-{{ section.id }}" class="pro-carousel">

  <div class="pro-carousel-wrapper">

    <div class="pro-carousel-track">

      {% for block in section.blocks %}
        <div class="pro-slide" {{ block.shopify_attributes }}>

          <!-- Desktop -->
          <div class="pro-media pro-desktop">
            {{ block.settings.desktop_image | image_url: width: 3000 | image_tag: class: 'pro-image' }}
          </div>

          <!-- Mobile -->
          <div class="pro-media pro-mobile">
            {% if block.settings.mobile_image != blank %}
              {{ block.settings.mobile_image | image_url: width: 1500 | image_tag: class: 'pro-image' }}
            {% else %}
              {{ block.settings.desktop_image | image_url: width: 1500 | image_tag: class: 'pro-image' }}
            {% endif %}
          </div>

          {% if block.settings.heading != blank or block.settings.text != blank or block.settings.button_label != blank %}
            <div class="pro-content">
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}
              {% if block.settings.button_label != blank %}
                <a href="{{ block.settings.button_link }}" class="pro-btn">
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>
          {% endif %}

        </div>
      {% endfor %}

    </div>

    <button class="pro-arrow prev">
      
  <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
  <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
</svg>
</button>
    <button class="pro-arrow next">
    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
  <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"/>
</svg>
    </button>

  </div>
</section>

<style>
.pro-carousel { position: relative; overflow: hidden; }

.pro-carousel-wrapper {
  position: relative;
  overflow: hidden;
  {% if section.settings.height_option == 'custom' %}
    height: {{ section.settings.custom_height }}px;
  {% endif %}
}

.pro-carousel-track {
  display: flex;
  transition: transform 0.6s ease;
}

.pro-slide {
  min-width: 100%;
  position: relative;
  {% if section.settings.height_option == 'custom' %}
    height: 100%;
  {% endif %}
}

.pro-image {
  width: 100%;
  display: block;
  {% if section.settings.height_option == 'custom' %}
    height: 100%;
    object-fit: cover;
  {% else %}
    height: auto;
  {% endif %}
}

.pro-mobile { display: none; }

@media (max-width: 749px) {
  .pro-desktop { display: none; }
  .pro-mobile { display: block; }
}

/* Text Colors */
.pro-content h2 {
  color: {{ section.settings.title_color }};
}

.pro-content p {
  color: {{ section.settings.text_color }};
}

.pro-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  text-align: center;
  max-width: 600px;
}

/* Button Style */
.pro-btn {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 20px;
  background: {{ section.settings.button_bg }};
  color: {{ section.settings.button_text_color }};
  text-decoration: none;
  border-radius: {{ section.settings.button_radius }}px;
}

/* Arrow Style */
.pro-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: {{ section.settings.arrow_bg }};
  color: {{ section.settings.arrow_color }};
  border-radius: {{ section.settings.arrow_radius }}px;
  border: none;
  padding: 2px 12px;
  cursor: pointer;
  z-index: 5;
}

.pro-arrow.prev { left: 20px; }
.pro-arrow.next { right: 20px; }
div#shopify-section-template--18281955459135__pro_carousel_slider_mTNfcU {
    max-width: 1440px;
    margin: 0 auto;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const section = document.getElementById("pro-carousel-{{ section.id }}");
  const track = section.querySelector(".pro-carousel-track");
  const slides = section.querySelectorAll(".pro-slide");
  const nextBtn = section.querySelector(".next");
  const prevBtn = section.querySelector(".prev");

  let index = 1;
  const total = slides.length;

  const firstClone = slides[0].cloneNode(true);
  const lastClone = slides[total - 1].cloneNode(true);

  track.appendChild(firstClone);
  track.insertBefore(lastClone, slides[0]);

  const allSlides = section.querySelectorAll(".pro-slide");

  track.style.transform = `translateX(-100%)`;

  function move() {
    track.style.transition = "transform 0.6s ease";
    track.style.transform = `translateX(-${index * 100}%)`;
  }

  function next() {
    if (index >= allSlides.length - 1) return;
    index++;
    move();
  }

  function prev() {
    if (index <= 0) return;
    index--;
    move();
  }

  nextBtn.addEventListener("click", next);
  prevBtn.addEventListener("click", prev);

  track.addEventListener("transitionend", function () {
    if (allSlides[index].isEqualNode(firstClone)) {
      track.style.transition = "none";
      index = 1;
      track.style.transform = `translateX(-${index * 100}%)`;
    }
    if (allSlides[index].isEqualNode(lastClone)) {
      track.style.transition = "none";
      index = total;
      track.style.transform = `translateX(-${index * 100}%)`;
    }
  });

});
</script>

{% schema %}
{
  "name": "Pro Carousel Slider",
  "settings": [
    {
      "type": "select",
      "id": "height_option",
      "label": "Height Option",
      "options": [
        { "value": "auto", "label": "Auto Height" },
        { "value": "custom", "label": "Custom Height" }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "Custom Height (px)",
      "min": 300,
      "max": 900,
      "step": 10,
      "default": 600
    },

    { "type": "header", "content": "Arrow Style" },
    { "type": "color", "id": "arrow_color", "label": "Arrow Icon Color", "default": "#ffffff" },
    { "type": "color", "id": "arrow_bg", "label": "Arrow Background Color", "default": "#000000" },
    { "type": "range", "id": "arrow_radius", "label": "Arrow Border Radius", "min": 0, "max": 50, "step": 1, "default": 4 },

    { "type": "header", "content": "Text Style" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Description Color", "default": "#ffffff" },

    { "type": "header", "content": "Button Style" },
    { "type": "color", "id": "button_bg", "label": "Button Background Color", "default": "#000000" },
    { "type": "color", "id": "button_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "range", "id": "button_radius", "label": "Button Border Radius", "min": 0, "max": 50, "step": 1, "default": 4 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "button_label", "label": "Button Label" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pro Carousel Slider",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
